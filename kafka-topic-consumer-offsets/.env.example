# Copy to .env in this directory (see README). .env is gitignored.
#
# Set KAFKA_BOOTSTRAP_SERVERS for exactly one target, e.g.:
#   Local Docker:  localhost:9092  (see docker-compose.yaml; leave API keys empty)
#   Confluent Cloud:  your ...confluent.cloud:9092  (set API key + secret)
#
# The script only enables SASL_SSL when BOTH KAFKA_API_KEY and
# KAFKA_API_SECRET (or KAFKA_API_SECRETS) are set.

KAFKA_BOOTSTRAP_SERVERS=

# Confluent Cloud API key (SASL/PLAIN user/password — not HTTP Bearer)
KAFKA_API_KEY=
# Preferred name; KAFKA_API_SECRETS is also accepted for the secret value
KAFKA_API_SECRET=
