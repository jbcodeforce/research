# Copy to .env in this directory (see README). .env is gitignored.

# Confluent Cloud: cluster bootstrap (Kafka protocol, port 9092 for SASL)
KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxxxxxxx.region.provider.confluent.cloud:9092

# API key pair from Confluent Cloud (used as SASL/PLAIN user/password — not HTTP Bearer)
KAFKA_API_KEY=
# Preferred name; KAFKA_API_SECRETS is also accepted for the secret value
KAFKA_API_SECRET=
